<Application x:Class="UltraTask.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:conv="clr-namespace:UltraTask.Converters"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Styles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <!-- Conversor global bool → Visibility -->
            <conv:BoolToVisibilityConverter x:Key="BoolToVisibility" />

            <!-- Estilo global de fonte para alta densidade -->
            <Style TargetType="TextBlock">
                <Setter Property="FontFamily" Value="Segoe UI" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            </Style>

<!-- Tooltip escuro global -->
            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource BgPanel}" />
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                <Setter Property="BorderBrush" Value="{DynamicResource BorderSubtle}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="Padding" Value="6,3" />
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
