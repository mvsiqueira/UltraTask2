<Window x:Class="UltraTask.Views.TagManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gerenciar Tags"
        Width="420" Height="500"
        MinWidth="360" MinHeight="300"
        Background="{StaticResource BgDeep}"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Formulário de nova tag -->
        <Border Grid.Row="0"
                Background="{StaticResource BgPanel}"
                CornerRadius="4" Padding="10,8" Margin="0,0,0,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" x:Name="NewTagName"
                         
                         Background="{StaticResource BgRow}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource BorderSubtle}"
                         Padding="6,3" Margin="0,0,6,0"
                         KeyDown="OnNewTagKeyDown" />

                <TextBox Grid.Column="1" x:Name="NewTagSize"
                         
                         Width="40"
                         Background="{StaticResource BgRow}"
                         Foreground="{StaticResource TextPrimary}"
                         BorderBrush="{StaticResource BorderSubtle}"
                         Padding="4,3" Margin="0,0,6,0"
                         ToolTip="Largura fixa em caracteres (vazio = auto)" />

                <!-- Swatch de cor -->
                <Border Grid.Column="2" x:Name="ColorSwatch"
                        Width="24" Height="24" CornerRadius="3"
                        Background="#2563EB" Margin="0,0,6,0"
                        Cursor="Hand" MouseLeftButtonDown="OnPickColor"
                        ToolTip="Clique para escolher cor" />

                <Button Grid.Column="3" Content="+ Adicionar"
                        Click="OnAddTag"
                        Style="{StaticResource SidebarButtonStyle}"
                        Width="Auto" Padding="8,0" />
            </Grid>
        </Border>

        <!-- Lista de tags -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="TagList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{StaticResource BgRow}"
                                BorderBrush="{StaticResource BorderSubtle}"
                                BorderThickness="0,0,0,1"
                                Padding="8,4">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="16" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="40" />
                                    <ColumnDefinition Width="24" />
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="22" />
                                    <ColumnDefinition Width="22" />
                                </Grid.ColumnDefinitions>

                                <!-- Swatch de cor -->
                                <Border Grid.Column="0" Width="12" Height="12"
                                        CornerRadius="2"
                                        Background="{Binding Color}"
                                        Cursor="Hand"
                                        Tag="{Binding}"
                                        MouseLeftButtonDown="OnEditTagColor" />

                                <!-- Nome editável -->
                                <TextBox Grid.Column="1"
                                         Text="{Binding Name, UpdateSourceTrigger=LostFocus}"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextPrimary}"
                                         BorderThickness="0"
                                         Padding="4,0"
                                         Tag="{Binding}"
                                         LostFocus="OnTagNameChanged" />

                                <!-- Tamanho -->
                                <TextBox Grid.Column="2"
                                         Text="{Binding Size, UpdateSourceTrigger=LostFocus}"
                                         Background="Transparent"
                                         Foreground="{StaticResource TextMuted}"
                                         BorderThickness="0"
                                         Padding="2,0"
                                         ToolTip="Largura fixa (chars)"
                                         Tag="{Binding}"
                                         LostFocus="OnTagSizeChanged" />

                                <!-- Cor hex display -->
                                <TextBlock Grid.Column="3"
                                           Text="{Binding Color}"
                                           FontSize="9"
                                           Foreground="{StaticResource TextMuted}"
                                           VerticalAlignment="Center" />

                                <!-- Mover para cima -->
                                <Button Grid.Column="4" Content="↑"
                                        FontSize="11"
                                        Tag="{Binding}"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Width="20" Height="20"
                                        Click="OnMoveUp" />

                                <!-- Mover para baixo -->
                                <Button Grid.Column="5" Content="↓"
                                        FontSize="11"
                                        Tag="{Binding}"
                                        Style="{StaticResource SidebarButtonStyle}"
                                        Width="20" Height="20"
                                        Click="OnMoveDown" />

                                <!-- Excluir -->
                                <Button Grid.Column="6" Content="×"
                                        FontSize="13"
                                        Tag="{Binding}"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Width="20" Height="20"
                                        Click="OnDeleteTag" />
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Rodapé -->
        <StackPanel Grid.Row="2" Orientation="Horizontal"
                    HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Fechar" Click="OnClose"
                    Style="{StaticResource LinkButtonStyle}"
                    Padding="12,6" />
        </StackPanel>
    </Grid>
</Window>
