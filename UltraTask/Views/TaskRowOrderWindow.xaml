<Window x:Class="UltraTask.Views.TaskRowOrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ordem das colunas"
        Width="300" Height="360"
        Background="{DynamicResource BgDeep}"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Text="Ative ou desative tokens e use as setas para reordenar."
                   Foreground="{DynamicResource TextMuted}"
                   FontSize="11"
                   TextWrapping="Wrap"
                   Margin="0,0,0,10" />

        <!-- Lista de tokens -->
        <Border Grid.Row="1"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="4">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="TokenList" Margin="4" />
            </ScrollViewer>
        </Border>

        <!-- Botões -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancelar" Width="80" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"
                    Style="{StaticResource NeutralButtonStyle}" />
            <Button Content="Salvar" Width="80"
                    Click="OnSave" IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
