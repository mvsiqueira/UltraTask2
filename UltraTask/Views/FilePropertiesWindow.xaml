<Window x:Class="UltraTask.Views.FilePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Propriedades do Arquivo"
        Width="320" Height="420"
        Background="{StaticResource BgDeep}"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Cabeçalho da seção -->
        <TextBlock Grid.Row="0"
                   Text="Ordem dos campos"
                   Foreground="{StaticResource TextPrimary}"
                   FontSize="12" FontWeight="SemiBold"
                   Margin="0,0,0,4" />

        <!-- Lista de tokens -->
        <Border Grid.Row="1"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="1"
                CornerRadius="4"
                Margin="0,0,0,0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="TokenList" Margin="4" />
            </ScrollViewer>
        </Border>

        <!-- Botões -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancelar" Width="80" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"
                    Style="{StaticResource NeutralButtonStyle}" />
            <Button Content="Salvar" Width="80"
                    Click="OnSave" IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
