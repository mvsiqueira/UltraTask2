<Window x:Class="UltraTask.Views.AppSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurações"
        Width="420" Height="280"
        Background="{DynamicResource BgDeep}"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <Style TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" VerticalAlignment="Top">

            <!-- Arquivo de tarefas -->
            <TextBlock Text="Arquivo de tarefas"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0"
                        Background="{DynamicResource BgPanel}"
                        BorderBrush="{DynamicResource BorderSubtle}"
                        BorderThickness="1" CornerRadius="4"
                        Padding="8,5" Margin="0,0,6,0">
                    <TextBlock x:Name="FilePathLabel"
                               Foreground="{DynamicResource TextSecondary}"
                               FontSize="11"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" />
                </Border>
                <Button Grid.Column="1" Content="Selecionar..."
                        Click="OnSelectFile"
                        Style="{StaticResource NeutralButtonStyle}" />
            </Grid>

            <!-- Tema -->
            <TextBlock Text="Tema"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <ComboBox x:Name="ThemeCombo"
                      Margin="0,0,0,16"
                      Style="{StaticResource FilterComboStyle}"
                      HorizontalAlignment="Left" Width="160">
                <ComboBoxItem Content="Escuro" Tag="dark" />
                <ComboBoxItem Content="Claro" Tag="light" />
            </ComboBox>

            <!-- Layout -->
            <TextBlock Text="Layout da lista"
                       Foreground="{DynamicResource TextPrimary}"
                       FontSize="12" FontWeight="SemiBold"
                       Margin="0,0,0,6" />
            <ComboBox x:Name="LayoutCombo"
                      Style="{StaticResource FilterComboStyle}"
                      HorizontalAlignment="Left" Width="160">
                <ComboBoxItem Content="Compacto" Tag="compact" />
                <ComboBoxItem Content="Normal"   Tag="normal" />
                <ComboBoxItem Content="Estendido" Tag="extended" />
            </ComboBox>

        </StackPanel>

        <!-- Botões -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancelar" Margin="0,0,8,0"
                    Click="OnCancel" IsCancel="True"
                    Style="{StaticResource NeutralButtonStyle}" />
            <Button Content="Salvar"
                    Click="OnSave" IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
