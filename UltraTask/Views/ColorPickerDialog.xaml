<Window x:Class="UltraTask.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escolher cor"
        Width="320" Height="260"
        Background="{StaticResource BgDeep}"
        WindowStyle="ToolWindow"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16">
        <TextBlock Text="Cor em hexadecimal (#RRGGBB):"
                   Foreground="{StaticResource TextSecondary}"
                   Margin="0,0,0,8" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="HexInput"
                     Background="{StaticResource BgRow}"
                     Foreground="{StaticResource TextPrimary}"
                     BorderBrush="{StaticResource BorderSubtle}"
                     Padding="6,4" Margin="0,0,8,0"
                     TextChanged="OnHexChanged" />
            <Border Grid.Column="1" x:Name="Preview"
                    Width="32" Height="32" CornerRadius="4"
                    Background="Gray" />
        </Grid>

        <!-- Paleta de cores predefinidas -->
        <WrapPanel Margin="0,12,0,0" x:Name="PalettePanel" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Click="OnCancel"
                    Style="{StaticResource LinkButtonStyle}" Padding="10,4" Margin="0,0,8,0" />
            <Button Content="OK" Click="OnOk"
                    Background="{StaticResource Accent}"
                    Foreground="White" BorderThickness="0"
                    Padding="16,4" />
        </StackPanel>
    </StackPanel>
</Window>
