<Window x:Class="UltraTask.Views.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Escolher cor"
        Width="320" Height="260"
        Background="{DynamicResource BgDeep}"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <StackPanel Margin="16">
        <TextBlock Text="Cor em hexadecimal (#RRGGBB):"
                   Foreground="{DynamicResource TextSecondary}"
                   Margin="0,0,0,8" />

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="36" />
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" x:Name="HexInput"
                     Background="{DynamicResource BgRow}"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderBrush="{DynamicResource BorderSubtle}"
                     Padding="6,4" Margin="0,0,8,0"
                     TextChanged="OnHexChanged" />
            <Border Grid.Column="1" x:Name="Preview"
                    Width="32" Height="32" CornerRadius="4"
                    Background="Gray" />
        </Grid>

        <!-- Paleta de cores predefinidas -->
        <WrapPanel Margin="0,12,0,0" x:Name="PalettePanel" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Cancelar" Click="OnCancel" IsCancel="True"
                    Style="{StaticResource NeutralButtonStyle}" Margin="0,0,8,0" />
            <Button Content="OK" Click="OnOk" IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </StackPanel>
</Window>
