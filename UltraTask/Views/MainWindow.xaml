<Window x:Class="UltraTask.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UltraTask.ViewModels"
        xmlns:ctrl="clr-namespace:UltraTask.Controls"
        Title="UltraTask"
        Icon="/Resources/app-icon.ico"
        Width="{Binding Settings.WindowWidth, Mode=TwoWay}"
        Height="{Binding Settings.WindowHeight, Mode=TwoWay}"
        MinWidth="600" MinHeight="400"
        Background="{StaticResource BgDeep}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}" />
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding ReloadCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveNowCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="48" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- BARRA LATERAL -->
        <Border Grid.Column="0"
                Background="{StaticResource BgPanel}"
                BorderBrush="{StaticResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" ToolTip="Sobre"
                        Click="OpenAbout" Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE946;" />
                </Button>

                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button ToolTip="Adicionar tarefa (Ctrl+N)"
                            Command="{Binding AddTaskCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE710;" />
                    </Button>
                    <Button ToolTip="Adicionar seção"
                            Command="{Binding AddSectionCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE8F4;" />
                    </Button>

                    <Separator Margin="4,4" Background="{StaticResource BorderSubtle}" />

                    <ToggleButton ToolTip="Operações em lote"
                                  IsChecked="{Binding BatchModeActive}"
                                  Style="{StaticResource SidebarToggleStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE762;" />
                    </ToggleButton>
                    <Button ToolTip="Recarregar arquivo (Ctrl+R)"
                            Command="{Binding ReloadCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE72C;" />
                    </Button>

                    <Separator Margin="4,4" Background="{StaticResource BorderSubtle}" />

                    <Button ToolTip="Gerenciar tags"
                            Click="OpenTagManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE8EC;" />
                    </Button>
                    <Button ToolTip="Gerenciar papéis"
                            Click="OpenRoleManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE77B;" />
                    </Button>
                    <Button ToolTip="Gerenciar links"
                            Click="OpenLinkManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE71B;" />
                    </Button>
                    <Button ToolTip="Propriedades do arquivo"
                            Click="OpenFileProperties"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE90F;" />
                    </Button>

                    <Separator Margin="4,4" Background="{StaticResource BorderSubtle}" />

                    <Button ToolTip="Configurações do app"
                            Click="OpenAppSettings"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="18" Text="&#xE713;" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- AREA PRINCIPAL -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Cabecalho -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="12,6">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <ctrl:InlineTextEditor Grid.Column="0"
                                           Text="{Binding FileTitle, Mode=TwoWay}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimary}"
                                           VerticalAlignment="Center"
                                           EditConfirmed="OnFileTitleConfirmed" />

                </Grid>
            </Border>

            <!-- Linha de filtros -->
            <Border Grid.Row="1"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock Text="Tag:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableTags}"
                              Text="{Binding FilterTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <TextBlock Text="Contato:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableContacts}"
                              Text="{Binding FilterContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <TextBlock Text="Designado:" Foreground="{StaticResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableAssignees}"
                              Text="{Binding FilterAssignee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <CheckBox Content="Importantes" Margin="0,0,8,0"
                              IsChecked="{Binding FilterImportantOnly}"
                              Foreground="{StaticResource TextSecondary}"
                              VerticalAlignment="Center" />

                    <Button Content="X Limpar"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Visibility="{Binding HasActiveFilter, Converter={StaticResource BoolToVisibility}}" />

                </WrapPanel>
            </Border>

            <!-- Lista principal com overlay de drop -->
            <Grid Grid.Row="2">
                <ScrollViewer x:Name="MainScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{StaticResource BgDeep}">
                    <ItemsControl x:Name="TaskList"
                                  ItemsSource="{Binding FilteredItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                <ctrl:TaskRowControl
                                    Item="{Binding}"
                                    TaskRowOrder="{Binding DataContext.TaskRowOrder, RelativeSource={RelativeSource AncestorType=Window}}"
                                    RoleConfig="{Binding DataContext.RoleConfig, RelativeSource={RelativeSource AncestorType=Window}}"
                                    RoleConfigVersion="{Binding DataContext.RoleConfigVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                    LayoutVersion="{Binding DataContext.LayoutVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                    TagCatalog="{Binding DataContext.TagCatalog, RelativeSource={RelativeSource AncestorType=Window}}"
                                    LinkCatalog="{Binding DataContext.LinkCatalog, RelativeSource={RelativeSource AncestorType=Window}}"
                                    BatchModeActive="{Binding DataContext.BatchModeActive, RelativeSource={RelativeSource AncestorType=Window}}"
                                    DeleteRequested="OnDeleteRequested"
                                    DuplicateRequested="OnDuplicateRequested"
                                    DragStarted="OnDragStarted"
                                    ItemChanged="OnItemChanged"
                                    FilterByTag="OnFilterByTag"
                                    FilterByContact="OnFilterByContact"
                                    FilterByAssignee="OnFilterByAssignee" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Canvas overlay: indicador de drop (linha azul) -->
                <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
                    <Border x:Name="DropIndicator"
                            Visibility="Collapsed"
                            Height="2"
                            Width="3000"
                            Background="{StaticResource Accent}" />
                </Canvas>
            </Grid>

            <!-- Barra de status -->
            <Border Grid.Row="3"
                    Background="{StaticResource BgPanel}"
                    BorderBrush="{StaticResource BorderSubtle}"
                    BorderThickness="0,1,0,0"
                    Padding="8,2">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <TextBlock x:Name="StatusText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10"
                                   VerticalAlignment="Center" />
                        <TextBlock x:Name="FilePathText"
                                   Foreground="{StaticResource TextMuted}"
                                   FontSize="10"
                                   Opacity="0.6"
                                   VerticalAlignment="Center"
                                   Margin="12,0,0,0" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               x:Name="BuildStamp"
                               Foreground="{StaticResource TextMuted}"
                               FontSize="10"
                               VerticalAlignment="Center" />
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
