<Window x:Class="UltraTask.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:UltraTask.ViewModels"
        xmlns:ctrl="clr-namespace:UltraTask.Controls"
        Title="UltraTask"
        Icon="/Resources/app-icon.ico"
        Width="{Binding Settings.WindowWidth, Mode=TwoWay}"
        Height="{Binding Settings.WindowHeight, Mode=TwoWay}"
        MinWidth="600" MinHeight="400"
        Background="{DynamicResource BgDeep}"
        WindowStyle="SingleBorderWindow">

    <Window.InputBindings>
        <KeyBinding Key="N" Modifiers="Ctrl" Command="{Binding AddTaskCommand}" />
        <KeyBinding Key="R" Modifiers="Ctrl" Command="{Binding ReloadCommand}" />
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{Binding SaveNowCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="60" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- CABECALHO (largura total) -->
        <Border Grid.Row="0" Grid.ColumnSpan="2"
                Background="{DynamicResource BgHeader}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="16,10">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                <!-- Ícone UltraTask: 3 barras brancas transparentes + sparkle Ultrasoft -->
                <Viewbox Width="36" Height="36" Margin="0,0,12,0" VerticalAlignment="Center">
                    <Canvas Width="100" Height="100">
                        <!-- barra 1 -->
                        <Rectangle Canvas.Left="10" Canvas.Top="13" Width="76" Height="20" RadiusX="7" RadiusY="7"
                                   Fill="White" Opacity="1" StrokeThickness="1.5" Stroke="#CBD5E1"/>
                        <Rectangle Canvas.Left="20" Canvas.Top="20" Width="30" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="#888888" Opacity="0.25"/>
                        <Rectangle Canvas.Left="54" Canvas.Top="20" Width="18" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="#888888" Opacity="0.18"/>
                        <!-- barra 2 -->
                        <Rectangle Canvas.Left="10" Canvas.Top="40" Width="76" Height="20" RadiusX="7" RadiusY="7"
                                   Fill="White" Opacity="0.65" StrokeThickness="1.5" Stroke="#CBD5E1"/>
                        <Rectangle Canvas.Left="20" Canvas.Top="47" Width="36" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="#888888" Opacity="0.20"/>
                        <Rectangle Canvas.Left="60" Canvas.Top="47" Width="14" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="#888888" Opacity="0.15"/>
                        <!-- barra 3 -->
                        <Rectangle Canvas.Left="10" Canvas.Top="67" Width="76" Height="20" RadiusX="7" RadiusY="7"
                                   Fill="White" Opacity="0.32" StrokeThickness="1.5" Stroke="#CBD5E1"/>
                        <Rectangle Canvas.Left="20" Canvas.Top="74" Width="24" Height="3" RadiusX="1.5" RadiusY="1.5"
                                   Fill="#888888" Opacity="0.15"/>
                        <!-- sparkle Ultrasoft — centrado em (72,73), raio 26 -->
                        <Path Fill="#C89B3C"
                              Data="M72,47 C74.3,63.9 81.1,70.7 98,73 C81.1,75.3 74.3,82.1 72,99 C69.7,82.1 62.9,75.3 46,73 C62.9,70.7 69.7,63.9 72,47Z"/>
                    </Canvas>
                </Viewbox>

                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="UltraTask"
                               FontSize="10"
                               Foreground="{DynamicResource HeaderFg}"
                               Opacity="0.55" />
                    <ctrl:InlineTextEditor
                        Text="{Binding FileTitle, Mode=TwoWay}"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Foreground="{DynamicResource HeaderFg}"
                        EditConfirmed="OnFileTitleConfirmed" />
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- BARRA LATERAL -->
        <Border Grid.Row="1" Grid.RowSpan="2" Grid.Column="0"
                Background="{DynamicResource BgSidebar}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <Button DockPanel.Dock="Bottom" ToolTip="Sobre"
                        Click="OpenAbout" Style="{StaticResource SidebarButtonStyle}">
                    <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE946;" />
                </Button>

                <StackPanel VerticalAlignment="Top" Margin="0,8,0,0">
                    <Button ToolTip="Adicionar tarefa (Ctrl+N)"
                            Command="{Binding AddTaskCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE710;" />
                    </Button>
                    <Button ToolTip="Adicionar seção"
                            Command="{Binding AddSectionCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xECC8;" />
                    </Button>

                    <Separator Margin="4,4" Background="{DynamicResource BorderSubtle}" />

                    <ToggleButton ToolTip="Operações em lote"
                                  IsChecked="{Binding BatchModeActive}"
                                  Style="{StaticResource SidebarToggleStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE762;" />
                    </ToggleButton>
                    <Button ToolTip="Recarregar arquivo (Ctrl+R)"
                            Command="{Binding ReloadCommand}"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE72C;" />
                    </Button>

                    <Separator Margin="4,4" Background="{DynamicResource BorderSubtle}" />

                    <Button ToolTip="Gerenciar tags"
                            Click="OpenTagManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE8EC;" />
                    </Button>
                    <Button ToolTip="Gerenciar papéis"
                            Click="OpenRoleManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE77B;" />
                    </Button>
                    <Button ToolTip="Gerenciar links"
                            Click="OpenLinkManager"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE71B;" />
                    </Button>
                    <Button ToolTip="Propriedades do arquivo"
                            Click="OpenFileProperties"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE90F;" />
                    </Button>

                    <Separator Margin="4,4" Background="{DynamicResource BorderSubtle}" />

                    <Button ToolTip="Configurações do app"
                            Click="OpenAppSettings"
                            Style="{StaticResource SidebarButtonStyle}">
                        <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="20" Foreground="{DynamicResource SidebarFg}" Text="&#xE713;" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- AREA PRINCIPAL -->
        <Grid Grid.Row="1" Grid.RowSpan="2" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Linha de filtros -->
            <Border Grid.Row="0"
                    Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource BorderSubtle}"
                    BorderThickness="0,0,0,1"
                    Padding="8,4">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <TextBlock Text="Tag:" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableTags}"
                              Text="{Binding FilterTag, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <TextBlock Text="Designado:" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableAssignees}"
                              Text="{Binding FilterAssignee, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <TextBlock Text="Contato:" Foreground="{DynamicResource TextMuted}"
                               VerticalAlignment="Center" Margin="0,0,4,0" />
                    <ComboBox Width="110" Margin="0,0,8,0"
                              ItemsSource="{Binding AvailableContacts}"
                              Text="{Binding FilterContact, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True"
                              Style="{StaticResource FilterComboStyle}" />

                    <CheckBox Margin="0,0,8,0"
                              IsChecked="{Binding FilterImportantOnly}"
                              VerticalAlignment="Center">
                        <TextBlock Text="Importantes" Foreground="{DynamicResource TextMuted}" />
                    </CheckBox>

                    <Button Content="X Limpar"
                            Command="{Binding ClearFiltersCommand}"
                            Style="{StaticResource DangerButtonStyle}"
                            Visibility="{Binding HasActiveFilter, Converter={StaticResource BoolToVisibility}}" />

                </StackPanel>
            </Border>

            <!-- Lista principal com overlay de drop -->
            <Grid Grid.Row="1">
                <ScrollViewer x:Name="MainScroll"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              Background="{DynamicResource BgSection}">
                    <ItemsControl x:Name="TaskList"
                                  ItemsSource="{Binding FilteredItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:TaskItemViewModel}">
                                <ctrl:TaskRowControl
                                    Item="{Binding}"
                                    TaskRowOrder="{Binding DataContext.TaskRowOrder, RelativeSource={RelativeSource AncestorType=Window}}"
                                    RoleConfig="{Binding DataContext.RoleConfig, RelativeSource={RelativeSource AncestorType=Window}}"
                                    RoleConfigVersion="{Binding DataContext.RoleConfigVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                    LayoutVersion="{Binding DataContext.LayoutVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                    TagCatalog="{Binding DataContext.TagCatalog, RelativeSource={RelativeSource AncestorType=Window}}"
                                    LinkCatalog="{Binding DataContext.LinkCatalog, RelativeSource={RelativeSource AncestorType=Window}}"
                                    BatchModeActive="{Binding DataContext.BatchModeActive, RelativeSource={RelativeSource AncestorType=Window}}"
                                    DeleteRequested="OnDeleteRequested"
                                    DuplicateRequested="OnDuplicateRequested"
                                    DragStarted="OnDragStarted"
                                    ItemChanged="OnItemChanged"
                                    FilterByTag="OnFilterByTag"
                                    FilterByContact="OnFilterByContact"
                                    FilterByAssignee="OnFilterByAssignee" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <!-- Canvas overlay: indicador de drop (linha azul) -->
                <Canvas x:Name="OverlayCanvas" IsHitTestVisible="False">
                    <Border x:Name="DropIndicator"
                            Visibility="Collapsed"
                            Height="2"
                            Width="3000"
                            Background="{DynamicResource Accent}" />
                </Canvas>
            </Grid>

        </Grid>

        <!-- BARRA DE STATUS (largura total) -->
        <Border Grid.Row="3" Grid.ColumnSpan="2"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="8,2">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock x:Name="StatusText"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10"
                               VerticalAlignment="Center" />
                    <TextBlock x:Name="FilePathText"
                               Foreground="{DynamicResource TextMuted}"
                               FontSize="10"
                               Opacity="0.6"
                               VerticalAlignment="Center"
                               Margin="12,0,0,0" />
                </StackPanel>

                <TextBlock Grid.Column="1"
                           x:Name="BuildStamp"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="10"
                           VerticalAlignment="Center" />
            </Grid>
        </Border>

    </Grid>
</Window>

