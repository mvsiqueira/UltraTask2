<Window x:Class="UltraTask.Views.NotesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Notas"
        Width="560" Height="400"
        MinWidth="400" MinHeight="280"
        Background="{DynamicResource BgDeep}"
        WindowStyle="ToolWindow"
        ShowInTaskbar="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,0,0,1"
                Padding="4,3">
            <WrapPanel Orientation="Horizontal">

                <!-- Formatação básica -->
                <ToggleButton x:Name="BtnBold" Content="B" Width="26" Height="24"
                              FontWeight="Bold" FontSize="12"
                              ToolTip="Negrito (Ctrl+B)"
                              Style="{StaticResource SidebarToggleStyle}"
                              Click="OnBold" />
                <ToggleButton x:Name="BtnItalic" Content="I" Width="26" Height="24"
                              FontStyle="Italic" FontSize="12"
                              ToolTip="Itálico (Ctrl+I)"
                              Style="{StaticResource SidebarToggleStyle}"
                              Click="OnItalic" />
                <ToggleButton x:Name="BtnUnderline" Width="26" Height="24"
                              FontSize="12"
                              ToolTip="Sublinhado (Ctrl+U)"
                              Style="{StaticResource SidebarToggleStyle}"
                              Click="OnUnderline">
                    <TextBlock TextDecorations="Underline" Text="U" />
                </ToggleButton>
                <ToggleButton x:Name="BtnStrike" Width="26" Height="24"
                              FontSize="12"
                              ToolTip="Tachado"
                              Style="{StaticResource SidebarToggleStyle}"
                              Click="OnStrikethrough">
                    <TextBlock TextDecorations="Strikethrough" Text="S" />
                </ToggleButton>

                <!-- Separador -->
                <Border Width="1" Height="18" Background="{DynamicResource BorderSubtle}" Margin="4,0" />

                <!-- Cor de texto -->
                <Button Width="26" Height="24" ToolTip="Cor do texto"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="OnPickTextColor">
                    <StackPanel>
                        <TextBlock Text="A" FontSize="11" FontWeight="Bold"
                                   HorizontalAlignment="Center" />
                        <Border x:Name="TextColorBar" Height="3" Margin="2,0"
                                Background="#EF4444" />
                    </StackPanel>
                </Button>

                <!-- Cor de fundo -->
                <Button Width="26" Height="24" ToolTip="Cor de fundo do texto"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="OnPickBgColor">
                    <StackPanel>
                        <TextBlock Text="▨" FontSize="11"
                                   HorizontalAlignment="Center" />
                        <Border x:Name="BgColorBar" Height="3" Margin="2,0"
                                Background="#F59E0B" />
                    </StackPanel>
                </Button>

                <!-- Separador -->
                <Border Width="1" Height="18" Background="{DynamicResource BorderSubtle}" Margin="4,0" />

                <!-- Checklist -->
                <Button Content="☐" Width="26" Height="24" FontSize="13"
                        ToolTip="Inserir item de checklist"
                        Style="{StaticResource SidebarButtonStyle}"
                        Click="OnInsertCheckbox" />

            </WrapPanel>
        </Border>

        <!-- Editor -->
        <RichTextBox x:Name="Editor"
                     Grid.Row="1"
                     Background="{DynamicResource BgDeep}"
                     Foreground="{DynamicResource TextPrimary}"
                     BorderThickness="0"
                     Padding="12,8"
                     FontFamily="Segoe UI"
                     FontSize="12"
                     AcceptsTab="True"
                     SpellCheck.IsEnabled="False"
                     SelectionChanged="OnSelectionChanged"
                     PreviewMouseDown="OnEditorPreviewMouseDown">
            <RichTextBox.Resources>
                <Style TargetType="Paragraph">
                    <Setter Property="Margin" Value="0" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="LineHeight" Value="18" />
                </Style>
            </RichTextBox.Resources>
        </RichTextBox>

        <!-- Rodapé -->
        <Border Grid.Row="2"
                Background="{DynamicResource BgPanel}"
                BorderBrush="{DynamicResource BorderSubtle}"
                BorderThickness="0,1,0,0"
                Padding="8,6">
            <Grid>
                <TextBlock x:Name="StatusText"
                           Foreground="{DynamicResource TextMuted}"
                           FontSize="10"
                           VerticalAlignment="Center"
                           Text="Clique em ☐/☒ para alternar estado" />
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Limpar" Click="OnClear"
                            Style="{StaticResource DangerButtonStyle}"
                            Padding="10,4" Margin="0,0,8,0" />
                    <Button Content="Cancelar" Click="OnCancel" IsCancel="True"
                            Style="{StaticResource NeutralButtonStyle}"
                            Padding="10,4" Margin="0,0,8,0" />
                    <Button Content="Salvar" Click="OnSave" IsDefault="True"
                            Style="{StaticResource AccentButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
