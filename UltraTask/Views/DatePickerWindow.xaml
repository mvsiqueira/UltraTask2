<Window x:Class="UltraTask.Views.DatePickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Data de vencimento"
        SizeToContent="WidthAndHeight"
        Background="{DynamicResource BgDeep}"
        WindowStyle="ToolWindow"
        ResizeMode="CanResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Calendário inline — sem dropdown -->
        <Calendar x:Name="Cal" Grid.Row="0" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Limpar" Margin="0,0,6,0"
                    Click="OnClear"
                    Style="{StaticResource DangerButtonStyle}" />
            <Button Content="Cancelar" Margin="0,0,6,0"
                    Click="OnCancel" IsCancel="True"
                    Style="{StaticResource NeutralButtonStyle}" />
            <Button Content="OK"
                    Click="OnOk" IsDefault="True"
                    Style="{StaticResource AccentButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
