<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Paleta base do UltraTask — fundo escuro, alta densidade -->
    <Color x:Key="BgDeepColor">#111827</Color>
    <Color x:Key="BgPanelColor">#1F2937</Color>
    <Color x:Key="BgRowColor">#1A2130</Color>
    <Color x:Key="BgRowHoverColor">#243044</Color>
    <Color x:Key="BgRowSelectedColor">#1E3A5F</Color>
    <Color x:Key="BgSectionColor">#0F1721</Color>
    <Color x:Key="BorderSubtleColor">#374151</Color>
    <Color x:Key="TextPrimaryColor">#F9FAFB</Color>
    <Color x:Key="TextSecondaryColor">#9CA3AF</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="ImportantEarColor">#DC2626</Color>

    <!-- Brushes derivados dos colors — usam DynamicResource para suportar troca de tema em runtime -->
    <SolidColorBrush x:Key="BgDeep"          Color="{DynamicResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgPanel"         Color="{DynamicResource BgPanelColor}" />
    <SolidColorBrush x:Key="BgRow"           Color="{DynamicResource BgRowColor}" />
    <SolidColorBrush x:Key="BgRowHover"      Color="{DynamicResource BgRowHoverColor}" />
    <SolidColorBrush x:Key="BgRowSelected"   Color="{DynamicResource BgRowSelectedColor}" />
    <SolidColorBrush x:Key="BgSection"       Color="{DynamicResource BgSectionColor}" />
    <SolidColorBrush x:Key="BorderSubtle"    Color="{DynamicResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="TextPrimary"     Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary"   Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMuted"       Color="{DynamicResource TextMutedColor}" />
    <SolidColorBrush x:Key="Accent"          Color="{DynamicResource AccentColor}" />
    <SolidColorBrush x:Key="Danger"          Color="{DynamicResource DangerColor}" />
    <SolidColorBrush x:Key="ImportantEar"    Color="{DynamicResource ImportantEarColor}" />
    <SolidColorBrush x:Key="BgSidebar"      Color="{DynamicResource BgPanelColor}" />
    <SolidColorBrush x:Key="SidebarFg"      Color="{DynamicResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="SidebarHover"   Color="{DynamicResource BgRowHoverColor}" />
    <SolidColorBrush x:Key="BgHeader"       Color="{DynamicResource BgPanelColor}" />
    <SolidColorBrush x:Key="HeaderFg"       Color="{DynamicResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="Transparent"     Color="Transparent" />

    <!-- Dimensões globais -->
    <Thickness x:Key="RowPadding">4,2,4,2</Thickness>
    <Thickness x:Key="ChipPadding">5,1,5,1</Thickness>
    <CornerRadius x:Key="ChipRadius">3</CornerRadius>
    <CornerRadius x:Key="BalloonRadius">10</CornerRadius>
    <sys:Double x:Key="RowHeight">26</sys:Double>
    <sys:Double x:Key="SectionHeight">36</sys:Double>
    <sys:Double x:Key="FontSizeBase">12</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="SidebarWidth">36</sys:Double>
    <Thickness x:Key="RowSpacing">0,0,0,0</Thickness>
    <sys:Double x:Key="TokenSpacing">3</sys:Double>

</ResourceDictionary>
