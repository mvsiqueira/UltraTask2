<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- Paleta base do UltraTask — fundo escuro, alta densidade -->
    <Color x:Key="BgDeepColor">#111827</Color>
    <Color x:Key="BgPanelColor">#1F2937</Color>
    <Color x:Key="BgRowColor">#1A2130</Color>
    <Color x:Key="BgRowHoverColor">#243044</Color>
    <Color x:Key="BgRowSelectedColor">#1E3A5F</Color>
    <Color x:Key="BgSectionColor">#0F1721</Color>
    <Color x:Key="BorderSubtleColor">#374151</Color>
    <Color x:Key="TextPrimaryColor">#F9FAFB</Color>
    <Color x:Key="TextSecondaryColor">#9CA3AF</Color>
    <Color x:Key="TextMutedColor">#6B7280</Color>
    <Color x:Key="AccentColor">#3B82F6</Color>
    <Color x:Key="DangerColor">#EF4444</Color>
    <Color x:Key="ImportantEarColor">#DC2626</Color>

    <!-- Brushes derivados dos colors -->
    <SolidColorBrush x:Key="BgDeep"          Color="{StaticResource BgDeepColor}" />
    <SolidColorBrush x:Key="BgPanel"         Color="{StaticResource BgPanelColor}" />
    <SolidColorBrush x:Key="BgRow"           Color="{StaticResource BgRowColor}" />
    <SolidColorBrush x:Key="BgRowHover"      Color="{StaticResource BgRowHoverColor}" />
    <SolidColorBrush x:Key="BgRowSelected"   Color="{StaticResource BgRowSelectedColor}" />
    <SolidColorBrush x:Key="BgSection"       Color="{StaticResource BgSectionColor}" />
    <SolidColorBrush x:Key="BorderSubtle"    Color="{StaticResource BorderSubtleColor}" />
    <SolidColorBrush x:Key="TextPrimary"     Color="{StaticResource TextPrimaryColor}" />
    <SolidColorBrush x:Key="TextSecondary"   Color="{StaticResource TextSecondaryColor}" />
    <SolidColorBrush x:Key="TextMuted"       Color="{StaticResource TextMutedColor}" />
    <SolidColorBrush x:Key="Accent"          Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="Danger"          Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="ImportantEar"    Color="{StaticResource ImportantEarColor}" />
    <SolidColorBrush x:Key="Transparent"     Color="Transparent" />

    <!-- Dimensões globais -->
    <Thickness x:Key="RowPadding">4,2,4,2</Thickness>
    <Thickness x:Key="ChipPadding">5,1,5,1</Thickness>
    <CornerRadius x:Key="ChipRadius">3</CornerRadius>
    <CornerRadius x:Key="BalloonRadius">10</CornerRadius>
    <sys:Double x:Key="RowHeight">26</sys:Double>
    <sys:Double x:Key="SectionHeight">24</sys:Double>
    <sys:Double x:Key="FontSizeBase">12</sys:Double>
    <sys:Double x:Key="FontSizeSmall">11</sys:Double>
    <sys:Double x:Key="SidebarWidth">36</sys:Double>

</ResourceDictionary>
